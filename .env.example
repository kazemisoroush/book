# ── Required ──────────────────────────────────────────────────
BOOK_PATH=path/to/book.txt
OUTPUT_DIR=output

# ── AWS (Bedrock for AI parsing) ──────────────────────────────
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-7
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ── Claude Code (agent client) ────────────────────────────────
ANTHROPIC_MODEL=us.anthropic.claude-opus-4-7
CLAUDE_CODE_EXTRA_BODY={"thinking":{"type":"adaptive"}}

# ── TTS Provider ──────────────────────────────────────────────
# Which provider to use: elevenlabs | local
TTS_PROVIDER=elevenlabs

# ElevenLabs
ELEVENLABS_API_KEY=

# Fish Audio
FISH_AUDIO_API_KEY=

# OpenAI TTS
OPENAI_API_KEY=

# ── SFX / Ambient / Music Providers ──────────────────────────
# Stability AI (Stable Audio — SFX + ambient)
STABILITY_API_KEY=

# Suno AI (music generation)
SUNO_API_KEY=

# ── Processing Options ────────────────────────────────────────
# Set to "true" to disable grouping beats
NO_GROUPING=false

# Set to "true" to skip combining audio files
NO_COMBINE=false

# Crossfade duration in seconds (omit to disable)
# CROSSFADE_DURATION=0.5

# ── Feature Flags ─────────────────────────────────────────────
# Set to "true" to only discover characters (no TTS)
DISCOVER_CHARACTERS=false

# Set to "true" to disable chapter announcements
NO_ANNOUNCE=false

# Set to "true" to disable transcript output
NO_TRANSCRIPTS=false
